# Ferreus env template. Copy to .env and fill in.

# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram chat id where notifications go
TELEGRAM_CHAT_ID=

# P0 enforces DRY_RUN. P3+ will allow LIVE.
DRY_RUN=true

# Detector cadence
POLL_INTERVAL_MS=20000
SCAN_BATCH_SIZE=20
DETECT_TOP_N=10000

# Filter thresholds
MIN_GAP_BPS=50
MIN_TVL_USD=50000
TRADE_SIZE_USD=1000

# How often to refresh the Jupiter token list
TOKEN_LIST_REFRESH_MS=*** SQLite file
# Helius RPC (free tier, https://helius.dev) — replace with your own key
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com/

DB_PATH=./data/ferreus.db

# debug | info | warn | error
LOG_LEVEL=info

ENABLED_DETECTORS=dex_dex,pool_watch,pool_arb

# Pool-3 testing
EXECUTION_ENABLED=true

# v0.8.1: SOL-denominated trading (0.01 SOL = 10M lamports ≈ $0.71 at SOL=$71)
# Quick test: 0.05 SOL ($3.50) — 5x modal, 5x Jupiter fees
ARB_TRADE_SIZE_SOL=0.01
ARB_MIN_PROFIT_SOL=0.0001
ARB_USE_DIRECT_DEX=true     # atomic 2-DEX quote (force route via specific DEX)

ARB_MAX_SLIPPAGE_BPS=50
ARB_MIN_GAP_BPS=100         # 1% minimum (was 30 = 0.3%)
ARB_MAX_PRICE_DEVIATION=2.0 # skip if price > 2x reference (filters dust pools)

# Ferreus env template. Copy to .env and fill in.

# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram chat id where notifications go
TELEGRAM_CHAT_ID=

# P0 enforces DRY_RUN. P3+ will allow LIVE.
DRY_RUN=true

# Detector cadence
# DETECT_TOP_N: how many top Jupiter tokens to scan (default 10000 — most of Jupiter's 13.6k list).
# SCAN_BATCH_SIZE: tokens to scan per tick. DexScreener limit is 5 RPS; with 200ms sleep,
# batch=20 + interval=20s ≈ 0.83 RPS (safe).
# At 10000 tokens / batch 20 = 500 ticks × 20s = 2.8h full rotation.
POLL_INTERVAL_MS=20000
SCAN_BATCH_SIZE=20
DETECT_TOP_N=10000

# Filter thresholds
MIN_GAP_BPS=50
MIN_TVL_USD=50000
TRADE_SIZE_USD=1000

# How often to refresh the Jupiter token list
TOKEN_LIST_REFRESH_MS=3600000

# Enabled detectors (comma-separated). Default: dex_dex only (most stable, ~$5-15/jam).
# Options: dex_dex, new_pool, pumpfun
# Note: new_pool + pumpfun require Geyser gRPC or paid RPC for real new-pool events
# (otherwise they get 429s from public Solana RPC). Leave off for paper trading.
# Detector E (Phase Pool-2): cross-DEX arb detection (CLMM↔Whirlpool gaps)
ARB_MIN_GAP_BPS=30
ARB_COOLDOWN_MS=60000
# Pool-2.7: skip dust pools (USD). 0 = disabled (let everything through).
ARB_MIN_TVL_USD=0
# Pool-3: trade size (in SOL per arb). 0.01 SOL = 10M lamports ≈ $0.71 at SOL=$71
ARB_TRADE_SIZE_SOL=0.01
# Pool-3: min profit threshold (in SOL). Default 0.0001 SOL ≈ 0.7¢
ARB_MIN_PROFIT_SOL=0.0001
# Pool-3: max slippage (bps) for Jupiter quote
ARB_MAX_SLIPPAGE_BPS=50

# Pool-2.5: vault balance reader (needed for CPMM price)
VAULT_READER_ENABLED=true
VAULT_REFRESH_MS=10000

# Pool-3 master switch: enables executor
EXECUTION_ENABLED=false
# Pool-3: trade mode (false = simulate, true = real on-chain)
LIVE_EXECUTE=false
# Pool-3/4: Jito tip (lamports) for bundle submission
JITO_TIP_LAMPORTS=10000
# Pool-3: priority fee (lamports) for tx
PRIORITY_FEE_LAMPORTS=1000
# Pool-3: Jito block engine URL (default: mainnet)
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf/api/v1/bundles
# Pool-5: wallet private key (base58 or B64: prefix). REQUIRED for LIVE_EXECUTE=true.
# SECURITY: never commit. Set via env or secrets manager.
# WALLET_PRIVATE_KEY=

ENABLED_DETECTORS=dex_dex,pool_watch,pool_arb
# Example: SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
# Without this, falls back to https://api.mainnet-beta.solana.com/ (heavily rate-limited, not for prod).

# SQLite file
DB_PATH=./data/ferreus.db

# debug | info | warn | error
LOG_LEVEL=info

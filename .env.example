# Ferreus env template. Copy to .env and fill in.

# Telegram bot token (from BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram chat id where notifications go
TELEGRAM_CHAT_ID=

# P0 enforces DRY_RUN. P3+ will allow LIVE.
DRY_RUN=true

# Detector cadence
POLL_INTERVAL_MS=5000
SCAN_BATCH_SIZE=5
DETECT_TOP_N=200

# Filter thresholds
MIN_GAP_BPS=50
MIN_TVL_USD=50000
TRADE_SIZE_USD=1000

# How often to refresh the Jupiter token list
TOKEN_LIST_REFRESH_MS=*** Helius free tier works great. Get your key at https://helius.dev (100k credits/day, free).
# Example: SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY_HERE
# Without this, falls back to https://api.mainnet-beta.solana.com/ (heavily rate-limited, not for prod).

# SQLite file
DB_PATH=./data/ferreus.db

# debug | info | warn | error
LOG_LEVEL=info
